rules_version = '2';

// Sicherheitsregeln für die Platzbelegung.
//
// Modell laut Absprache:
//  - Jeder (anonym angemeldet) darf den Plan LESEN.
//  - Trainer dürfen Wünsche und Trainingstage SCHREIBEN (ohne echtes Konto).
//  - Belegungen und Sperren sind dem Admin vorbehalten.
//
// Da der Admin in dieser Variante nur per Frontend-Passwort erkannt wird
// (kein serverseitiges Konto), kann Firestore den Admin nicht zuverlässig
// von einem Trainer unterscheiden. Deshalb sind hier zwei Stufen vorgesehen:
//
//  Stufe A (Standard, einfach): bookings/locks dürfen von jedem angemeldeten
//  Nutzer geschrieben werden. Das Frontend zeigt die Schreib-UI nur dem Admin.
//  Praktikabel für einen Vereinsbetrieb, aber technisch umgehbar.
//
//  Stufe B (härter, empfohlen bei Bedarf): Admin bekommt ein echtes Konto mit
//  Custom Claim `admin:true` (siehe README). Dann die mit /* B */ markierten
//  Zeilen aktivieren und die Stufe-A-Zeilen entfernen.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    /* B */ // function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    match /bookings/{id} {
      allow read: if signedIn();
      allow write: if signedIn();              // Stufe A
      /* B */ // allow write: if isAdmin();    // Stufe B
    }

    match /locks/{id} {
      allow read: if signedIn();
      allow write: if signedIn();              // Stufe A
      /* B */ // allow write: if isAdmin();    // Stufe B
    }

    match /wishes/{id} {
      allow read: if signedIn();
      allow create: if signedIn();             // Trainer dürfen Wünsche anlegen
      allow update, delete: if signedIn();     // Status setzen (Admin im Frontend)
      /* B */ // allow update, delete: if isAdmin();
    }

    match /trainingDays/{teamId} {
      allow read: if signedIn();
      allow write: if signedIn();              // Trainer melden Trainingstage
    }
  }
}
